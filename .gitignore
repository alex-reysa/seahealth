# Data — do not commit raw datasets
*.csv
*.xlsx
*.parquet
data/
tables/

# But DO commit small synthetic fixtures used by tests
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.parquet
!tests/fixtures/**/*.xlsx

# MLflow / Databricks
mlruns/
mlartifacts/
