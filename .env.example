DATABRICKS_HOST=https://dbc-d6ef5b01-b491.cloud.databricks.com
DATABRICKS_TOKEN=dapi_REPLACE_ME
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT=/Shared/seahealth/extraction-runs

# LLM provider auto-routes by model id: a slash routes to OpenRouter
# (https://openrouter.ai/api/v1) using OPENROUTER_API_KEY; otherwise the
# id routes to Databricks Foundation Models. Defaults below use OpenRouter
# + anthropic/claude-haiku-4.5 because that combination ships reliable
# tool-use on Indian-facility text. Other tested-good fallbacks:
#   - databricks-meta-llama-3-3-70b-instruct (Databricks Foundation Models)
#   - moonshotai/kimi-k2.5 (OpenRouter — cheaper but ~30% tool-call refusal)
SEAHEALTH_LLM_HEAVY_MODEL=anthropic/claude-haiku-4.5
SEAHEALTH_LLM_LIGHT_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
