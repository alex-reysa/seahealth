# SeaHealth env example. Copy to .env and fill in real values; never
# commit a populated .env. The placeholders below are intentionally
# obviously-fake so secret scanners don't false-flag this file.

# --- Databricks ---
DATABRICKS_HOST=https://dbc-EXAMPLE.cloud.databricks.com
DATABRICKS_TOKEN=dapi-EXAMPLE-TOKEN-NOT-REAL
# Optional: serverless SQL warehouse path. Without it, /health/data reports
# mode=parquet (or fixture if no parquet on disk).
DATABRICKS_SQL_HTTP_PATH=
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT=/Shared/seahealth/extraction-runs

# --- Mosaic AI Vector Search ---
# When both are set, /health/data reports retriever_mode=vector_search.
# Otherwise the local FAISS / BM25 / TF fallback is used.
SEAHEALTH_VS_ENDPOINT=seahealth-vs
SEAHEALTH_VS_INDEX=workspace.seahealth_silver.chunks_index

# --- API mode + production posture ---
# Optional override (delta|parquet|fixture). Leave blank for auto-detect.
SEAHEALTH_API_MODE=
# CORS: comma-separated origin list. Default '*' enables permissive demo
# mode. Setting any non-wildcard value puts the API in production posture:
# /health/data redacts filesystem and Vector Search identifiers, and 503
# responses stop leaking raw exception text. Use this for any deployed env.
CORS_ALLOW_ORIGINS=*

# --- LLM provider ---
# A slash in the model id routes to OpenRouter (uses OPENROUTER_API_KEY).
# An id without a slash routes to Databricks Foundation Models (uses
# DATABRICKS_TOKEN). Tested-good fallbacks for SEAHEALTH_LLM_HEAVY_MODEL:
#   - databricks-meta-llama-3-3-70b-instruct (Databricks Foundation Models)
#   - moonshotai/kimi-k2.5 (OpenRouter — cheaper but ~30% tool-call refusal)
SEAHEALTH_LLM_HEAVY_MODEL=anthropic/claude-haiku-4.5
SEAHEALTH_LLM_LIGHT_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_API_KEY=sk-or-v1-EXAMPLE-NOT-REAL

# --- Frontend ---
# VITE_SEAHEALTH_API_BASE=http://localhost:8000
# VITE_SEAHEALTH_API_MODE=demo  # or 'live'
