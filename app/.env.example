# Frontend → backend wiring. The client at app/src/api/client.ts:resolveApiMode()
# reads these two vars at build time:
#   - VITE_SEAHEALTH_API_BASE: base URL the React app prefixes onto every API
#     call. Set to "/api" when frontend + backend are co-deployed on Vercel.
#     Leave unset to render bundled fixture JSON (demo mode).
#   - VITE_SEAHEALTH_API_MODE: explicit override ("live" | "demo"). When unset,
#     mode is "live" iff VITE_SEAHEALTH_API_BASE is set.
VITE_SEAHEALTH_API_BASE=
VITE_SEAHEALTH_API_MODE=
