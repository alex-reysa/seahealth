# Keep pyproject.toml out so Vercel's Python builder falls back to the
# trimmed requirements.txt (pyproject.toml lists databricks-sdk +
# pandas which together push the bundle past Lambda's 500 MB limit).
pyproject.toml

# Keep the unused 3.7 MB chunks parquet out of the function bundle —
# the unwired retriever is the only consumer and the API never touches it.
tables/chunks.parquet
tables/capabilities.parquet
tables/contradictions.parquet
tables/evidence_assessments.parquet
